SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/CP
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

SPRING_JPA_HIBERNATE_DDL_AUTO=create
SPRING_JPA_SHOW_SQL=true

SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=you@example.com
SPRING_MAIL_PASSWORD=your-app-password

APP_JWT_SECRET=replace-with-strong-secret
APP_JWT_ACCESS_TOKEN_EXPIRATION=900000
APP_JWT_REFRESH_TOKEN_EXPIRATION=604800000
APP_FRONTEND_URL=http://localhost:4200
APP_EMAIL_VERIFICATION_EXPIRY_HOURS=24

APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
