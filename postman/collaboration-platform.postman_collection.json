              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{memberEmail}}\",\n  \"code\": \"{{memberVerificationCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-code"
              ]
            },
            "description": "Before running, replace collection variable memberVerificationCode with the 6-digit code sent by the backend."
          }
        },
        {
          "name": "Resend Member Verification Code",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/resend-code?email={{memberEmail}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "resend-code"
              ],
              "query": [
                {
                  "key": "email",
                  "value": "{{memberEmail}}"
                }
              ]
            },
            "description": "Use this if the member verification email/code is missing or expired. Copy the new code from MailHog into memberVerificationCode."
          }
        },
        {
          "name": "Login Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('memberUserId', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{memberEmail}}\",\n  \"password\": \"{{memberPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Logs in as the member and saves memberUserId. This replaces the current cookie session, so run Login Owner Again before Projects member-management requests."
          }
        },
        {
          "name": "Get Current Member Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('memberUserId', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Confirms the member session and saves memberUserId."
          }
        },
        {
          "name": "Login Owner Again",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Run this before Projects requests so the cookie session is the project owner."
          }
        }
      ]
    },
    {
      "name": "2. Projects",
      "description": "Requires a logged-in user. Run Login Owner first. Requests save projectRef as the project slug when available, plus projectMemberId when possible.",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('created project', function () {",
                  "  pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('projectRef', body.slug || body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"PFA Collaboration Platform\",\n  \"description\": \"Backend project module smoke test from Postman.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "projects"
              ]
            },
            "description": "Creates a project. The authenticated user automatically becomes OWNER."
          }
        },
        {
          "name": "List My Projects - Paginated",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/projects?page=0&size=20&sort=joinedAt,desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "projects"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                },
                {
                  "key": "sort",
                  "value": "joinedAt,desc"
                }
              ]
            },
            "description": "Returns PageResponse<ProjectResponse>. The backend default is size=20 and sort=joinedAt desc."
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectRef}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "projects",
                "{{projectRef}}"
              ]
            },
            "description": "Returns one project if the authenticated user is a member."
